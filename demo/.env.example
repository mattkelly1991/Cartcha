# CARTCHA demo configuration. Copy to `.env` and edit. All values are optional;
# sensible defaults apply and the server falls back to the static battery if the
# LLM minter is enabled but not fully configured.

# --- server ---
PORT=3000

# HMAC secret for success tokens. Set a long random value in production.
# CARTCHA_SECRET=replace-with-32+-random-bytes

# --- minter selection ---
# static = ship the pre-validated golden battery (default, no network)
# llm    = generate + validate keys on the fly via an LLM endpoint (see below)
CARTCHA_MINTER=static

# --- LLM minter (only used when CARTCHA_MINTER=llm) ---
# Any OpenAI-compatible /chat/completions endpoint (OpenAI, Azure, Together,
# OpenRouter, a local vLLM/Ollama gateway, etc.).
# CARTCHA_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# CARTCHA_LLM_KEY=sk-...
# CARTCHA_LLM_MODEL=gpt-4o-mini

# Minting knobs (optional)
# CARTCHA_LLM_KEYS=12          # how many golden keys to produce
# CARTCHA_LLM_CANDIDATES=24    # max candidate items to try
# CARTCHA_LLM_RUNS=3           # rankings sampled per candidate
# CARTCHA_LLM_MIN_COHESION=0.6 # keep a key only if mean pairwise Kendall-tau >= this
# CARTCHA_LLM_TOKENS=6         # tokens per item
#
# NOTE: real security needs CROSS-VENDOR convergence + human-scatter (GATE-2).
# The shipped llm.js is a single-endpoint scaffold; see its header to fan out across vendors.
